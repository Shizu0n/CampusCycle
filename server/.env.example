# --- Banco de dados ---------------------------------------------------------
# Runtime (queries): no Neon, use a URL POOLED (pgbouncer) com os parâmetros:
#   ?pgbouncer=true&connect_timeout=15
# Sem eles: erros intermitentes "prepared statement already exists" em produção.
DATABASE_URL="postgresql://campuscycle:campuscycle@localhost:5432/campuscycle"

# Migrations (prisma migrate): SEMPRE a URL DIRETA (sem pgbouncer).
# Local (docker-compose) as duas são iguais.
DIRECT_URL="postgresql://campuscycle:campuscycle@localhost:5432/campuscycle"

# --- Identidade -------------------------------------------------------------
# Resolver EXCLUSIVO: 'anonymous' (header X-User-Id) | 'jwt' (a partir do dia 6).
# Nunca empilhar os dois — ver src/middleware/identity.ts
IDENTITY_MODE="anonymous"

# --- Servidor ---------------------------------------------------------------
PORT=3001
# Origem do frontend para CORS (produção: domínio do Vercel). localhost já é permitido.
WEB_ORIGIN=""
